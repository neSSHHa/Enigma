@page
@model SetPasswordModel
@{
    ViewData["Title"] = "Create Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="security-container">
    <div class="security-card">
        <header class="security-header">
            <h1 class="security-title">Create Local Password</h1>
            <p class="security-subtitle">Set up password-based authentication</p>
        </header>

        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="security-notice">
            <svg class="info-icon" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" />
            </svg>
            <p>You're currently using external authentication. Create a local password for backup access.</p>
        </div>

        <form id="set-password-form" method="post" class="password-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="input-group">
                <label asp-for="Input.NewPassword">New Password</label>
                <input asp-for="Input.NewPassword"
                       autocomplete="new-password"
                       placeholder="Enter new password"
                       class="password-input">
                <span asp-validation-for="Input.NewPassword" class="validation-error"></span>
            </div>

            <div class="input-group">
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword"
                       autocomplete="new-password"
                       placeholder="Confirm new password"
                       class="password-input">
                <span asp-validation-for="Input.ConfirmPassword" class="validation-error"></span>
            </div>

            <button type="submit" class="security-btn">
                <svg class="btn-icon" viewBox="0 0 24 24">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z" />
                </svg>
                Set Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    :root {
        --primary-color: #6366f1;
        --text-primary: #f5f5f5;
        --text-secondary: #a3a3a3;
        --surface-dark: #2d2d2d;
        --input-bg: #191919;
        --error-color: #dc2626;
    }

    .security-container {
        max-width: 500px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .security-card {
        background: var(--surface-dark);
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .security-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .security-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .security-subtitle {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .security-notice {
        display: flex;
        gap: 1rem;
        padding: 1rem;
        background: rgba(99, 102, 241, 0.1);
        border-radius: 0.75rem;
        margin: 1.5rem 0;
        color: var(--text-primary);
    }

    .info-icon {
        flex-shrink: 0;
        width: 24px;
        height: 24px;
        color: var(--primary-color);
    }

    .password-form {
        display: grid;
        gap: 1.5rem;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    label {
        color: var(--text-primary);
        font-weight: 500;
        font-size: 0.9rem;
    }

    .password-input {
        width: 100%;
        padding: 0.875rem 1rem;
        background: var(--input-bg);
        border: 1px solid #404040;
        border-radius: 0.75rem;
        color: var(--text-primary);
        transition: all 0.2s ease;
    }

        .password-input:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
            outline: none;
        }

    .security-btn {
        width: 100%;
        padding: 1rem;
        background: var(--primary-color);
        color: white;
        border: none;
        border-radius: 0.75rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        transition: all 0.2s ease;
        margin-top: 1rem;
    }

        .security-btn:hover {
            background: #4f46e5;
            transform: translateY(-1px);
        }

    .btn-icon {
        width: 20px;
        height: 20px;
    }

    .validation-summary {
        color: var(--error-color);
        padding: 1rem;
        background: rgba(220, 38, 38, 0.1);
        border-radius: 0.75rem;
    }

    .validation-error {
        color: var(--error-color);
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }

    @@media (max-width: 480px) {
        .security-card {
            padding: 1.5rem;
        }
    }
</style>