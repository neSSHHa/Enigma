@page
@model ShowRecoveryCodesModel
@{
    ViewData["Title"] = "Recovery Codes";
    ViewData["ActivePage"] = "TwoFactorAuthentication";
}

<div class="security-container">
    <div class="security-card">
        <header class="security-header">
            <h1 class="security-title">Two-Factor Recovery Codes</h1>
            <p class="security-subtitle">Emergency access codes for your account</p>
        </header>

        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="critical-warning">
            <div class="warning-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                </svg>
            </div>
            <div class="warning-content">
                <h3 class="warning-title">Security Notice</h3>
                <ul class="warning-list">
                    <li>Store these codes in a secure password manager</li>
                    <li>Treat them with the same security as your password</li>
                    <li>Each code can only be used once</li>
                </ul>
            </div>
        </div>

        <div class="recovery-codes-container">
            <div class="codes-header">
                <span class="code-number">#</span>
                <span class="code-value">Recovery Code</span>
                <span class="code-copy">Copy</span>
            </div>

            <div class="codes-list">
                @for (var i = 0; i < Model.RecoveryCodes.Length; i++)
                {
                    <div class="code-item">
                        <span class="code-number">@(i + 1)</span>
                        <code class="code-value">@Model.RecoveryCodes[i]</code>
                        <button class="copy-btn" data-code="@Model.RecoveryCodes[i]">
                            <svg class="copy-icon" viewBox="0 0 24 24">
                                <path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" />
                            </svg>
                        </button>
                    </div>
                }
            </div>
        </div>

        <div class="save-instructions">
            <h3 class="instructions-title">Save Instructions</h3>
            <div class="save-options">
                <button class="save-option" onclick="print()">
                    <svg class="option-icon" viewBox="0 0 24 24">
                        <path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z" />
                    </svg>
                    Print Codes
                </button>
                <button class="save-option" id="downloadCodes">
                    <svg class="option-icon" viewBox="0 0 24 24">
                        <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
                    </svg>
                    Download TXT
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --surface-dark: #2d2d2d;
        --text-primary: #f5f5f5;
        --text-secondary: #a3a3a3;
        --primary-color: #6366f1;
        --warning-bg: #fffbeb;
        --warning-text: #92400e;
    }

    .security-container {
        max-width: 800px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .security-card {
        background: var(--surface-dark);
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .security-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .security-title {
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .security-subtitle {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .critical-warning {
        display: flex;
        gap: 1.5rem;
        padding: 1.5rem;
        background: var(--warning-bg);
        border-radius: 1rem;
        margin: 2rem 0;
    }

    .warning-icon {
        flex-shrink: 0;
        width: 32px;
        height: 32px;
        color: #f59e0b;
    }

    .warning-content {
        color: var(--warning-text);
    }

    .warning-title {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .warning-list {
        margin: 0;
        padding-left: 1.25rem;
    }

        .warning-list li {
            margin-bottom: 0.5rem;
        }

    .recovery-codes-container {
        background: #191919;
        border-radius: 1rem;
        overflow: hidden;
        margin: 2rem 0;
    }

    .codes-header {
        display: grid;
        grid-template-columns: 50px 1fr 60px;
        padding: 1rem;
        background: #2d2d2d;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .code-item {
        display: grid;
        grid-template-columns: 50px 1fr 60px;
        align-items: center;
        padding: 1rem;
        border-bottom: 1px solid #2d2d2d;
    }

    .code-value {
        font-family: monospace;
        font-size: 1.1rem;
        letter-spacing: 0.1em;
        color: var(--text-primary);
    }

    .copy-btn {
        background: none;
        border: none;
        padding: 0.25rem;
        cursor: pointer;
        color: var(--text-secondary);
        transition: all 0.2s ease;
    }

        .copy-btn:hover {
            color: var(--primary-color);
        }

    .copy-icon {
        width: 20px;
        height: 20px;
    }

    .save-instructions {
        border-top: 1px solid #404040;
        padding-top: 2rem;
    }

    .instructions-title {
        font-size: 1.1rem;
        color: var(--text-primary);
        margin-bottom: 1rem;
    }

    .save-options {
        display: flex;
        gap: 1rem;
    }

    .save-option {
        flex: 1;
        padding: 1rem;
        background: #191919;
        border: 1px solid #404040;
        border-radius: 0.75rem;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        transition: all 0.2s ease;
    }

        .save-option:hover {
            border-color: var(--primary-color);
            color: var(--primary-color);
        }

    .option-icon {
        width: 20px;
        height: 20px;
    }

    @@media (max-width: 640px) {
        .security-card {
            padding: 1.5rem;
        }

        .codes-header {
            display: none;
        }

        .code-item {
            grid-template-columns: 1fr auto;
            gap: 1rem;
        }

        .code-number {
            display: none;
        }
    }
</style>

<script>
    document.querySelectorAll('.copy-btn').forEach(button => {
        button.addEventListener('click', (e) => {
            const code = e.currentTarget.dataset.code;
            navigator.clipboard.writeText(code);

            const icon = e.currentTarget.querySelector('svg');
            icon.style.color = '#6366f1';
            setTimeout(() => icon.style.color = '', 1000);
        });
    });

    document.getElementById('downloadCodes').addEventListener('click', () => {
        const codes = @Html.Raw(Json.Serialize(Model.RecoveryCodes));
        const text = codes.join('\n');
        const blob = new Blob([text], { type: 'text/plain' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'recovery-codes.txt';
        a.click();
    });
</script>