@page
@model Disable2faModel
@{
    ViewData["Title"] = "Disable Two-Factor Authentication";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="security-container">
    <div class="security-card">
        <header class="security-header">
            <h1 class="security-title">@ViewData["Title"]</h1>
            <p class="security-subtitle">Manage your account security settings</p>
        </header>

        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="warning-alert">
            <div class="warning-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            <div class="warning-content">
                <h3 class="warning-title">Important Notice</h3>
                <p class="warning-text">
                    Disabling 2FA only removes the second authentication step. Your authenticator app keys
                    remain active. To completely reset your security configuration,
                    <a asp-page="./ResetAuthenticator" class="warning-link">reset your authenticator keys</a>.
                </p>
            </div>
        </div>

        <form method="post" class="security-actions">
            <button class="destructive-btn" type="submit">
                <svg class="btn-icon" viewBox="0 0 24 24">
                    <path d="M6 18L18 6M6 6l12 12" />
                </svg>
                Disable 2FA
            </button>
        </form>
    </div>
</div>

<style>
    :root {
        --warning-bg: #fffbeb;
        --warning-border: #f59e0b;
        --warning-text: #92400e;
        --destructive: #dc2626;
        --destructive-hover: #b91c1c;
    }

    .security-container {
        max-width: 640px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .security-card {
        background: white;
        border-radius: 1rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        padding: 2rem;
    }

    .security-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .security-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 0.5rem;
    }

    .security-subtitle {
        color: #64748b;
        font-size: 0.9rem;
    }

    .warning-alert {
        display: flex;
        gap: 1rem;
        padding: 1.5rem;
        background: var(--warning-bg);
        border-left: 4px solid var(--warning-border);
        border-radius: 0.5rem;
        margin: 2rem 0;
    }

    .warning-icon {
        flex-shrink: 0;
        width: 24px;
        height: 24px;
        color: var(--warning-border);
    }

        .warning-icon svg {
            width: 100%;
            height: 100%;
            stroke-width: 2;
        }

    .warning-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--warning-text);
        margin-bottom: 0.75rem;
    }

    .warning-text {
        color: var(--warning-text);
        line-height: 1.5;
        margin: 0;
    }

    .warning-link {
        color: var(--warning-text);
        font-weight: 500;
        text-decoration: underline;
    }

    .destructive-btn {
        width: 100%;
        padding: 1rem;
        background: var(--destructive);
        color: white;
        border: none;
        border-radius: 0.75rem;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        transition: all 0.2s ease;
    }

        .destructive-btn:hover {
            background: var(--destructive-hover);
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(220, 38, 38, 0.2);
        }

    .btn-icon {
        width: 20px;
        height: 20px;
        stroke: currentColor;
        stroke-width: 2;
    }

    @@media (max-width: 480px) {
        .security-card {
            padding: 1.5rem;
        }

        .security-title {
            font-size: 1.25rem;
        }
    }
</style>

<script>
    document.querySelector('.destructive-btn').addEventListener('click', function(e) {
        if (!confirm('Are you sure you want to disable two-factor authentication? This reduces your account security.')) {
            e.preventDefault();
        }
    });
</script>