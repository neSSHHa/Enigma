@page
@using Microsoft.AspNetCore.Http.Features
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="security-container">
    <div class="security-card">
        <header class="security-header">
            <h1 class="security-title">Two-Factor Authentication</h1>
            <p class="security-subtitle">Enhance your account security</p>
        </header>

        <partial name="_StatusMessage" for="StatusMessage" />

        @{
            var consentFeature = HttpContext.Features.Get<ITrackingConsentFeature>();
            @if (consentFeature?.CanTrack ?? true)
            {
                <div class="auth-status">
                    @if (Model.Is2faEnabled)
                    {
                        <div class="recovery-codes-alert">
                            @if (Model.RecoveryCodesLeft == 0)
                            {
                                <div class="critical-alert">
                                    <svg class="alert-icon" viewBox="0 0 24 24">
                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                                    </svg>
                                    <div>
                                        <h4>No Recovery Codes Remaining</h4>
                                        <p>You must <a asp-page="./GenerateRecoveryCodes">generate new codes</a> to maintain account access.</p>
                                    </div>
                                </div>
                            }
                            else if (Model.RecoveryCodesLeft == 1)
                            {
                                <div class="critical-alert">
                                    <svg class="alert-icon" viewBox="0 0 24 24">
                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                                    </svg>
                                    <div>
                                        <h4>1 Recovery Code Remaining</h4>
                                        <p>Immediately <a asp-page="./GenerateRecoveryCodes">generate new codes</a> to secure your account.</p>
                                    </div>
                                </div>
                            }
                            else if (Model.RecoveryCodesLeft <= 3)
                            {
                                <div class="warning-alert">
                                    <svg class="alert-icon" viewBox="0 0 24 24">
                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                                    </svg>
                                    <div>
                                        <h4>@Model.RecoveryCodesLeft Recovery Codes Left</h4>
                                        <p>Recommend <a asp-page="./GenerateRecoveryCodes">generating new codes</a> for backup access.</p>
                                    </div>
                                </div>
                            }

                            <div class="action-buttons">
                                @if (Model.IsMachineRemembered)
                                {
                                    <form method="post" class="inline-form">
                                        <button type="submit" class="security-btn ghost">
                                            <svg class="btn-icon" viewBox="0 0 24 24">
                                                <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                                            </svg>
                                            Forget This Device
                                        </button>
                                    </form>
                                }
                                <a asp-page="./Disable2fa" class="security-btn secondary">
                                    Disable 2FA
                                </a>
                                <a asp-page="./GenerateRecoveryCodes" class="security-btn secondary">
                                    Reset Recovery Codes
                                </a>
                            </div>
                        </div>
                    }

                    <div class="authenticator-section">
                        <h3 class="section-title">
                            <svg class="section-icon" viewBox="0 0 24 24">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" />
                            </svg>
                            Authenticator App
                        </h3>

                        <div class="auth-actions">
                            @if (!Model.HasAuthenticator)
                            {
                                <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="security-btn">
                                    <svg class="btn-icon" viewBox="0 0 24 24">
                                        <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                                    </svg>
                                    Add Authenticator
                                </a>
                            }
                            else
                            {
                                <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="security-btn">
                                    <svg class="btn-icon" viewBox="0 0 24 24">
                                        <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" />
                                    </svg>
                                    Configure Authenticator
                                </a>
                                <a id="reset-authenticator" asp-page="./ResetAuthenticator" class="security-btn secondary">
                                    <svg class="btn-icon" viewBox="0 0 24 24">
                                        <path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" />
                                    </svg>
                                    Reset Authenticator
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="consent-warning">
                    <svg class="warning-icon" viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                    </svg>
                    <div>
                        <h3>Privacy Consent Required</h3>
                        <p>You must accept our privacy policy to enable two-factor authentication.</p>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    :root {
        --primary-color: #6366f1;
        --destructive: #dc2626;
        --warning: #f59e0b;
        --surface-dark: #2d2d2d;
        --text-primary: #f5f5f5;
        --text-secondary: #a3a3a3;
    }

    .security-container {
        max-width: 800px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .security-card {
        background: var(--surface-dark);
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .security-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .security-title {
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .security-subtitle {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .critical-alert, .warning-alert, .consent-warning {
        display: flex;
        gap: 1rem;
        padding: 1.5rem;
        border-radius: 1rem;
        margin: 1.5rem 0;
    }

    .critical-alert {
        background: rgba(220, 38, 38, 0.15);
        border: 1px solid var(--destructive);
    }

    .warning-alert {
        background: rgba(245, 158, 11, 0.15);
        border: 1px solid var(--warning);
    }

    .consent-warning {
        background: rgba(220, 38, 38, 0.15);
        border: 1px solid var(--destructive);
    }

    .alert-icon, .warning-icon {
        flex-shrink: 0;
        width: 24px;
        height: 24px;
    }

    .critical-alert .alert-icon {
        color: var(--destructive);
    }

    .warning-alert .alert-icon {
        color: var(--warning);
    }

    .consent-warning .warning-icon {
        color: var(--destructive);
    }

    .action-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin: 2rem 0;
    }

    .security-btn {
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 500;
        transition: all 0.2s ease;
        text-decoration: none;
    }

        .security-btn:not(.ghost):not(.secondary) {
            background: var(--primary-color);
            color: white;
        }

        .security-btn.secondary {
            background: #404040;
            color: var(--text-primary);
            border: 1px solid #505050;
        }

        .security-btn.ghost {
            background: none;
            color: var(--text-primary);
            border: 1px solid #505050;
        }

        .security-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
        }

    .btn-icon {
        width: 20px;
        height: 20px;
    }

    .authenticator-section {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid #404040;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--text-primary);
        margin-bottom: 1.5rem;
    }

    .section-icon {
        width: 24px;
        height: 24px;
        color: var(--primary-color);
    }

    .auth-actions {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }

    @@media (max-width: 640px) {
        .security-card {
            padding: 1.5rem;
        }

        .auth-actions {
            grid-template-columns: 1fr;
        }
    }
</style>