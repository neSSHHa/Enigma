@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Set Up Authenticator App";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="auth-setup-container">
    <div class="security-card">
        <header class="security-header">
            <h1 class="security-title">Two-Factor Authentication Setup</h1>
            <p class="security-subtitle">Secure your account with an authenticator app</p>
        </header>

        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="setup-guide">
            <div class="setup-step">
                <div class="step-number">1</div>
                <div class="step-content">
                    <h3>Download an Authenticator App</h3>
                    <div class="app-badges">
                        <a href="https://go.microsoft.com/fwlink/?Linkid=825072" class="app-badge">
                            <img src="https://cdn.iconscout.com/icon/free/png-256/microsoft-authenticator-3521846-2945266.png" alt="Microsoft Authenticator">
                            <span>Microsoft Authenticator</span>
                        </a>
                        <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2" class="app-badge">
                            <img src="https://cdn.iconscout.com/icon/free/png-256/google-authenticator-3521848-2945268.png" alt="Google Authenticator">
                            <span>Google Authenticator</span>
                        </a>
                    </div>
                </div>
            </div>

            <div class="setup-step">
                <div class="step-number">2</div>
                <div class="step-content">
                    <h3>Configure Your App</h3>
                    <div class="configure-methods">
                        <div class="qr-section">
                            <div class="qr-container" id="qrCode"></div>
                            <div class="qr-note">Scan this QR code with your app</div>
                        </div>

                        <div class="manual-key">
                            <label>Or enter this secret key:</label>
                            <div class="key-box">
                                <code>@Model.SharedKey</code>
                                <button class="copy-btn" data-clipboard-text="@Model.SharedKey">
                                    <svg class="copy-icon" viewBox="0 0 24 24">
                                        <path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="setup-step">
                <div class="step-number">3</div>
                <div class="step-content">
                    <h3>Verify Setup</h3>
                    <form id="send-code" method="post" class="verification-form">
                        <div class="input-group">
                            <label asp-for="Input.Code">Enter verification code</label>
                            <input asp-for="Input.Code"
                                   autocomplete="off"
                                   placeholder="6-digit code from app"
                                   class="verification-input">
                            <span asp-validation-for="Input.Code" class="validation-error"></span>
                        </div>
                        <button type="submit" class="security-btn">
                            Verify &amp; Activate
                            <svg class="btn-icon" viewBox="0 0 24 24">
                                <path d="M10.3 8.7L16 3l1.4 1.4-7 7 7 7L16 20l-5.7-5.7-1.4-1.4 1.4-1.4z" />
                            </svg>
                        </button>
                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/clipboard.js/2.0.8/clipboard.min.js"></script>
    <script>
        new ClipboardJS('.copy-btn');
    </script>
}

<style>
    :root {
        --primary-color: #6366f1;
        --success-color: #16a34a;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
        --border-color: #e2e8f0;
    }

    .auth-setup-container {
        max-width: 800px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .security-card {
        background: white;
        border-radius: 1rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        padding: 2rem;
    }

    .security-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .security-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .security-subtitle {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .setup-step {
        display: flex;
        gap: 1.5rem;
        margin: 2rem 0;
        padding: 1.5rem;
        background: #f8fafc;
        border-radius: 1rem;
    }

    .step-number {
        width: 32px;
        height: 32px;
        background: var(--primary-color);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        flex-shrink: 0;
    }

    .step-content h3 {
        margin-top: 0;
        margin-bottom: 1rem;
        color: var(--text-primary);
    }

    .app-badges {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .app-badge {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        background: white;
        border-radius: 0.75rem;
        border: 1px solid var(--border-color);
        transition: transform 0.2s ease;
        text-decoration: none;
        color: var(--text-primary);
    }

        .app-badge:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .app-badge img {
            width: 32px;
            height: 32px;
        }

    .configure-methods {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }

    .qr-container {
        background: white;
        padding: 1rem;
        border-radius: 0.75rem;
        border: 1px solid var(--border-color);
    }

    .qr-note {
        color: var(--text-secondary);
        font-size: 0.875rem;
        margin-top: 0.5rem;
        text-align: center;
    }

    .manual-key {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .key-box {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
    }

        .key-box code {
            flex: 1;
            font-family: monospace;
            font-size: 0.9em;
            word-break: break-all;
        }

    .copy-btn {
        background: none;
        border: none;
        padding: 0.25rem;
        cursor: pointer;
        color: var(--text-secondary);
    }

    .copy-icon {
        width: 20px;
        height: 20px;
    }

    .verification-form {
        max-width: 400px;
    }

    .verification-input {
        width: 100%;
        padding: 0.875rem;
        border: 1px solid var(--border-color);
        border-radius: 0.75rem;
        font-size: 1.25rem;
        letter-spacing: 0.1em;
        text-align: center;
    }

    .security-btn {
        width: 100%;
        padding: 1rem;
        margin-top: 1rem;
        background: var(--primary-color);
        color: white;
        border: none;
        border-radius: 0.75rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        transition: all 0.2s ease;
    }

        .security-btn:hover {
            background: #4f46e5;
            transform: translateY(-1px);
        }

    @@media (max-width: 768px) {
        .configure-methods {
            grid-template-columns: 1fr;
        }

        .setup-step {
            flex-direction: column;
            align-items: start;
        }
    }
</style>