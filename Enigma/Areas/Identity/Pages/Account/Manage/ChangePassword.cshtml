@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="security-container">
    <div class="security-card">
        <header class="security-header">
            <h1 class="security-title">@ViewData["Title"]</h1>
            <p class="security-subtitle">Update your account password</p>
        </header>

        <div class="security-body">
            <partial name="_StatusMessage" for="StatusMessage" />

            <form id="change-password-form" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="input-group">
                    <label asp-for="Input.OldPassword">Current Password</label>
                    <input asp-for="Input.OldPassword"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder="Enter current password">
                    <span asp-validation-for="Input.OldPassword" class="validation-error"></span>
                </div>

                <div class="input-group">
                    <label asp-for="Input.NewPassword">New Password</label>
                    <input asp-for="Input.NewPassword"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="Create new password">
                    <span asp-validation-for="Input.NewPassword" class="validation-error"></span>
                </div>

                <div class="input-group">
                    <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="Confirm new password">
                    <span asp-validation-for="Input.ConfirmPassword" class="validation-error"></span>
                </div>

                <button type="submit" class="security-btn">
                    Update Password
                    <svg class="btn-icon" viewBox="0 0 24 24">
                        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M12 2v14m0 0l4-4m-4 4l-4-4" />
                    </svg>
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    :root {
        --primary-color: #6366f1;
        --error-color: #dc2626;
        --success-color: #16a34a;
        --background-light: #f8fafc;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
    }

    .security-container {
        max-width: 500px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .security-card {
        background: white;
        border-radius: 1rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        padding: 2rem;
    }

    .security-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .security-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .security-subtitle {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    .input-group {
        margin-bottom: 1.5rem;
        position: relative;
    }

        .input-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
            font-weight: 500;
            font-size: 0.9rem;
        }

        .input-group input {
            width: 100%;
            padding: 0.875rem;
            border: 1px solid #e2e8f0;
            border-radius: 0.75rem;
            font-size: 1rem;
            transition: all 0.2s ease;
        }

            .input-group input:focus {
                border-color: var(--primary-color);
                box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
                outline: none;
            }

    .validation-error {
        display: block;
        margin-top: 0.5rem;
        color: var(--error-color);
        font-size: 0.875rem;
        font-weight: 500;
    }

    .validation-summary {
        color: var(--error-color);
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: #fef2f2;
        border-radius: 0.75rem;
    }

    .security-btn {
        width: 100%;
        padding: 1rem;
        background: var(--primary-color);
        color: white;
        border: none;
        border-radius: 0.75rem;
        font-weight: 500;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        transition: all 0.2s ease;
    }

        .security-btn:hover {
            background: #4f46e5;
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(99, 102, 241, 0.2);
        }

    .btn-icon {
        width: 20px;
        height: 20px;
        stroke: currentColor;
    }

    @@media (max-width: 480px) {
        .security-card {
            padding: 1.5rem;
        }

        .security-title {
            font-size: 1.25rem;
        }
    }
</style>