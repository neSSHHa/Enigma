@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Recovery Code Verification";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                </svg>
            </div>
            <h1 class="auth-title">Emergency Access</h1>
            <p class="auth-subtitle">Use your recovery code to continue</p>
        </div>

        <div class="auth-notice">
            <svg class="info-icon" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
            </svg>
            <p>This login won't be remembered. For persistent access, configure 2FA after logging in.</p>
        </div>

        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="input-group">
                <label asp-for="Input.RecoveryCode">Recovery Code</label>
                <div class="code-input-container">
                    <input asp-for="Input.RecoveryCode"
                           class="code-input"
                           autocomplete="off"
                           placeholder="Enter 16-character code"
                           pattern="[A-Za-z0-9]{16}"
                           maxlength="16">
                    <svg class="input-icon" viewBox="0 0 24 24">
                        <path d="M17 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm2 16H5V5h11.17L19 7.83V19zm-7-7c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3zM6 6h9v4H6z" />
                    </svg>
                </div>
                <span asp-validation-for="Input.RecoveryCode" class="validation-error"></span>
            </div>

            <button type="submit" class="auth-button">
                Verify Recovery Code
                <svg class="button-icon" viewBox="0 0 24 24">
                    <path d="M10.3 8.7L16 3l1.4 1.4-7 7 7 7L16 20l-5.7-5.7-1.4-1.4 1.4-1.4z" />
                </svg>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    :root {
        --primary-color: #6366f1;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
        --input-bg: #f8fafc;
        --border-color: #e2e8f0;
        --error-color: #dc2626;
    }

    .auth-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
        background: #f1f5f9;
    }

    .auth-card {
        background: white;
        border-radius: 1.5rem;
        padding: 3rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        max-width: 500px;
        width: 100%;
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-icon {
        width: 60px;
        height: 60px;
        margin: 0 auto 1.5rem;
        color: var(--primary-color);
    }

        .auth-icon svg {
            width: 100%;
            height: 100%;
        }

    .auth-title {
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .auth-subtitle {
        color: var(--text-secondary);
        font-size: 1rem;
    }

    .auth-notice {
        display: flex;
        gap: 1rem;
        padding: 1.25rem;
        background: #f8fafc;
        border-radius: 0.75rem;
        margin: 2rem 0;
    }

    .info-icon {
        flex-shrink: 0;
        width: 24px;
        height: 24px;
        color: var(--primary-color);
    }

    .auth-form {
        display: grid;
        gap: 1.5rem;
    }

    .code-input-container {
        position: relative;
    }

    .code-input {
        width: 100%;
        padding: 0.875rem 1rem;
        background: var(--input-bg);
        border: 1px solid var(--border-color);
        border-radius: 0.75rem;
        font-family: monospace;
        letter-spacing: 0.1em;
        transition: all 0.2s ease;
    }

        .code-input:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
            outline: none;
        }

    .input-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        width: 20px;
        height: 20px;
        color: var(--text-secondary);
    }

    .auth-button {
        width: 100%;
        padding: 1rem;
        background: var(--primary-color);
        color: white;
        border: none;
        border-radius: 0.75rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        transition: all 0.2s ease;
    }

        .auth-button:hover {
            background: #4f46e5;
            transform: translateY(-1px);
        }

    .button-icon {
        width: 20px;
        height: 20px;
    }

    .validation-summary {
        color: var(--error-color);
        padding: 1rem;
        background: #fef2f2;
        border-radius: 0.75rem;
    }

    .validation-error {
        color: var(--error-color);
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }

    @@media (max-width: 480px) {
        .auth-card {
            padding: 2rem;
        }

        .auth-title {
            font-size: 1.5rem;
        }

        .code-input {
            font-size: 0.9rem;
        }
    }
</style>