@page
@model ConfirmEmailChangeModel
@{
    ViewData["Title"] = "Email Update Confirmed";
}

<div class="verification-container">
    <div class="verification-card">
        <div class="verification-icon success">
            <svg viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
            </svg>
        </div>
        <h1 class="verification-title">Email Updated</h1>
        <div class="verification-content">
            <partial name="_StatusMessage" model="Model.StatusMessage" />
            <p class="verification-text">Your account's email address has been successfully updated</p>
            <div class="verification-actions">
                <a href="/" class="verification-button">
                    <svg class="button-icon" viewBox="0 0 24 24">
                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
                    </svg>
                    Return to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --success-color: #16a34a;
        --success-bg: #f0fdf4;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
    }

    .verification-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
        background: var(--success-bg);
    }

    .verification-card {
        text-align: center;
        max-width: 500px;
        padding: 3rem;
        background: white;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .verification-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 1.5rem;
        color: var(--success-color);
    }

        .verification-icon svg {
            width: 100%;
            height: 100%;
        }

    .verification-title {
        font-size: 1.75rem;
        color: var(--text-primary);
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .verification-text {
        color: var(--text-secondary);
        margin: 1.5rem 0;
        line-height: 1.5;
    }

    .verification-actions {
        margin-top: 2rem;
    }

    .verification-button {
        padding: 0.75rem 1.5rem;
        background: var(--success-color);
        color: white;
        border-radius: 0.75rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        transition: all 0.2s ease;
    }

        .verification-button:hover {
            background: #15803d;
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(22, 163, 74, 0.2);
        }

    .button-icon {
        width: 20px;
        height: 20px;
    }

    @@media (max-width: 480px) {
        .verification-card {
            padding: 2rem;
        }

        .verification-title {
            font-size: 1.5rem;
        }
    }
</style>