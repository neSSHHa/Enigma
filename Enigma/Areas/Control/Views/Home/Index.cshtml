                    <p class="staggered-item" style="font-size: 1.5rem; margin-bottom: 3rem;">
                        Precision translations powered by AI-enhanced human expertise
                    </p>
                    <div class="staggered-item">
                        <a href="#pricing" class="cta-button">Start Global Journey →</a>
                    </div>
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-item text-center">
                    <div class="text-4xl font-bold text-primary">150+</div>
                    <div class="text-sm">Languages Supported</div>
                </div>
                <div class="stat-item text-center">
                    <div class="text-4xl font-bold text-primary">5K+</div>
                    <div class="text-sm">Professional Translators</div>
                </div>
                <div class="stat-item text-center">
                    <div class="text-4xl font-bold text-primary">1M+</div>
                    <div class="text-sm">Projects Completed</div>
                </div>
                <div class="stat-item text-center">
                    <div class="text-4xl font-bold text-primary">98%</div>
                    <div class="text-sm">Client Satisfaction</div>
                </div>
            </div>
        </section>

        <!-- Services Section -->
        <section class="container">
            <div class="services-grid">
                <div class="service-card staggered-item">
                    <div class="icon-box mb-4 text-4xl">🌐</div>
                    <h3 class="text-2xl font-bold mb-3">Enterprise Translation</h3>
                    <p class="text-gray-600">Secure, scalable solutions for technical documentation, legal contracts, and multinational campaigns.</p>
                </div>
                <div class="service-card staggered-item">
                    <div class="icon-box mb-4 text-4xl">🤖</div>
                    <h3 class="text-2xl font-bold mb-3">AI-Powered Localization</h3>
                    <p class="text-gray-600">Context-aware machine translation with human quality assurance for rapid deployment.</p>
                </div>
                <div class="service-card staggered-item">
                    <div class="icon-box mb-4 text-4xl">🏥</div>
                    <h3 class="text-2xl font-bold mb-3">Industry Specialists</h3>
                    <p class="text-gray-600">Medical, legal, and technical translations certified by subject matter experts.</p>
                </div>
            </div>
        </section>

    <section class="parallax-section" style="background-image: url('https://images.pexels.com/photos/1181396/pexels-photo-1181396.jpeg')">
        <div class="container">
            <div class="text-white relative z-10">
                <h2 class="text-4xl mb-4">Human Expertise, AI Precision</h2>
                <p class="text-xl max-w-2xl">Our hybrid model combines the nuance of native speakers with machine learning efficiency</p>
            </div>
        </div>
    </section>

        <!-- Testimonials -->
        <section class="container">
            <div class="testimonial-grid">
                <div class="testimonial-card staggered-item">
                    <img src="https://i.pravatar.cc/80?img=1" alt="Sarah Johnson" class="rounded-full mb-4 w-20 h-20">
                    <h4 class="font-bold mb-2">Sarah Johnson</h4>
                    <p class="text-sm text-gray-500">Localization Manager, TechCorp</p>
                    <p class="mt-4 italic">"The quality and speed transformed our global rollout process."</p>
                </div>
                <div class="testimonial-card staggered-item">
                    <img src="https://i.pravatar.cc/80?img=2" alt="Michael Chen" class="rounded-full mb-4 w-20 h-20">
                    <h4 class="font-bold mb-2">Michael Chen</h4>
                    <p class="text-sm text-gray-500">CEO, MedPharma Solutions</p>
                    <p class="mt-4 italic">"Precision-critical translations handled with expert care."</p>
                </div>
                <div class="testimonial-card staggered-item">
                    <img src="https://i.pravatar.cc/80?img=3" alt="Emma Müller" class="rounded-full mb-4 w-20 h-20">
                    <h4 class="font-bold mb-2">Emma Müller</h4>
                    <p class="text-sm text-gray-500">CMO, Global Fashion Group</p>
