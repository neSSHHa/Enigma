@{
    ViewData["Title"] = "Global Lingua Pro";
}

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="World-class language translation and localization services">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #1A365D;
            --accent: #FF6B6B;
            --dark: #0F172A;
            --light: #F8FAFC;
            --gradient: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

    .main-content{
        padding: 0;
    }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            line-height: 1.7;
            color: var(--dark);
            overflow-x: hidden;
        }

        .full-bleed {
            width: 100%;
            grid-column: 1 / -1;
        }

        .container {
            width: 100%;
            max-width: 1440px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* Hero Section */
        .hero-section {
            height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            align-items: center;
            background: var(--gradient);
            position: relative;
            overflow: hidden;
        }

        .hero-video {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.2;
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            color: white;
            padding: 4rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
            position: absolute;
            bottom: -5%;
            left: 50%;
            transform: translateX(-50%);
            width: 80%;
            background: white;
            padding: 3rem;
            border-radius: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
            z-index: 3;
        }

        /* Services Section */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 3rem;
            padding: 8rem 0;
        }

        .service-card {
            padding: 3rem;
            border-radius: 2rem;
            background: white;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(0,0,0,0.1);
            position: relative;
            overflow: hidden;
        }

            .service-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
            }

        /* Pricing Section */
        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            padding: 8rem 0;
        }

        .pricing-tier {
            padding: 2.5rem;
            border: 2px solid rgba(0,0,0,0.1);
            border-radius: 2rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            background: white;
        }

            .pricing-tier:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
            }

            .pricing-tier.professional {
                transform: scale(1.05);
                z-index: 2;
                border-color: var(--accent);
                box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
                background: var(--primary);
                color: white;
            }
            .pricing-tier.custome{
            background: var(--dark);
            box-shadow: 0 25px 50px -12px rgba(48,45,48,0.25);
            border-color: var(--accent);
        }

        .pricing-features li {
            position: relative;
            padding-left: 1.5rem;
            margin-bottom: 0.75rem;
        }

            .pricing-features li::before {
                content: '✓';
                position: absolute;
                left: 0;
                color: var(--accent);
            }

        /* Language Section */
        .language-carousel {
            display: flex;
            gap: 2rem;
            padding: 4rem 0;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            position: relative;
        }

            .language-carousel::after {
                content: '';
                position: absolute;
                right: 0;
                top: 0;
                bottom: 0;
                width: 100px;
                background: linear-gradient(90deg, rgba(248,250,252,0) 0%, var(--light) 100%);
            }

        .language-card {
            padding: 1.5rem;
            background: white;
            border-radius: 1.5rem;
            text-align: center;
            flex-shrink: 0;
            width: 220px;
            scroll-snap-align: start;
            transition: all 0.2s ease;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            display: grid;
            grid-template-rows: auto auto 1fr;
        }

            .language-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
            }

        /* Testimonials */
        .testimonial-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 3rem;
            padding: 8rem 0;
        }

        .testimonial-card {
            background: white;
            padding: 2rem;
            border-radius: 2rem;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }

    .parallax-section {
        height: 100vh;
        display: flex;
        align-items: center;
        background-attachment: fixed;
        background-size: cover;
        position: relative;
    }
        /* Utilities */
        .text-gradient {
            background: linear-gradient(45deg, #FFD700 0%, #FF6B6B 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .cta-button {
            display: inline-flex;
            align-items: center;
            padding: 1rem 2rem;
            background: var(--accent);
            color: white;
            border-radius: 50px;
            text-decoration: none;
            transition: all 0.3s ease;
            font-weight: 600;
            gap: 0.5rem;
        }

            .cta-button:hover {
                transform: translateY(-3px);
                box-shadow: 0 5px 15px -3px rgba(255,107,107,0.4);
            }

        .cta-reverse {
            background: white;
            color: var(--primary) !important;
            border: 2px solid var(--primary);
        }

        /* Animations */
        @@keyframes float {
            0%, 100% {
                transform: translateY(-50%) translateX(0) scale(1);
            }

            50% {
                transform: translateY(-55%) translateX(2%) scale(1.02);
            }
        }

        .staggered-item {
            opacity: 0;
            transform: translateY(50px);
            transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .is-visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* Mobile Styles */
        @@media (max-width: 1024px) {
            .hero-section {
                grid-template-columns: 1fr;
                text-align: center;
                height: auto;
                padding: 6rem 0;
            }

            .stats-grid {
                grid-template-columns: 1fr 1fr;
                position: static;
                transform: none;
                width: 100%;
                margin-top: 2rem;
                padding: 2rem;
            }

            .services-grid,
            .pricing-grid,
            .testimonial-grid {
                grid-template-columns: 1fr;
            }

            .pricing-tier.professional {
                transform: none;
                order: -1;
            }

            .language-card {
                width: 180px;
            }

            .hero-content {
                padding: 2rem;
            }
        }

        @@media (max-width: 640px) {
            .container {
                padding: 0 1rem;
            }

            .cta-button {
                width: 100%;
                justify-content: center;
            }
        }
    </style>

    <div class="wrapper">
        <!-- Hero Section -->
        <section class="hero-section">
            <video autoplay muted loop class="hero-video">
