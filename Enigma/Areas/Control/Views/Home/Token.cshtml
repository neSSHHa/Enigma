        </div>
        <div class="upload-zone" id="uploadZone">
            <h2>📤 Upload Payment Proof</h2>
            <p>Drag & drop or click to upload your payment receipt</p>
        </div>

        <div class="price-table">
            <h2>Token Pricing</h2>
            <div class="price-row">
                <span>1 Token</span>
                <span class="highlight">1,000 RSD</span>
            </div>
            <div class="price-row">
                <span>Basic Courses</span>
                <span>1-2 Tokens</span>
            </div>
            <div class="price-row">
                <span>Advanced Courses</span>
                <span>3-5 Tokens</span>
            </div>
            <div class="price-row">
                <span>Premium Courses</span>
                <span class="highlight">5+ Tokens</span>
            </div>
        </div>
    </div>
}
else
{
    // SREDI FUNCKIONALNOAT MALKO...
    //
    //
    //
    //
    //
    <div class="admin-container">
        <div class="admin-header">
            <h1 class="admin-title">Payment Verifications</h1>
            <div class="flex items-center gap-2">
                <span class="text-sm text-gray-500">@Model.Count() pending verifications</span>
            </div>
        </div>

        <div class="verification-grid">
            @foreach (var proof in Model)
            {
                <div class="verification-card">
                    <div class="user-header">
                        @if (!string.IsNullOrEmpty(proof.ApplicationUser.Image))
                        {
                            <img src="@proof.ApplicationUser.Image"
                                 class="user-avatar"
                                 alt="@proof.ApplicationUser.Name's avatar">
                        }
                        <div class="user-info">
                            <div class="user-name">@proof.ApplicationUser.Name</div>
                            <div class="user-email">@proof.ApplicationUser.Email</div>
                        </div>
                        <div class="token-badge">@proof.ApplicationUser.Tokens tokens</div>
                    </div>

                    <div class="payment-proof">
                        <img src="data:image/@proof.FileExtension;base64,@Convert.ToBase64String(proof.Bytes)"
                             class="proof-image"
                             alt="Payment proof from @proof.ApplicationUser.Name">
                    </div>

                    <div class="action-buttons">
                        <button class="action-button approve-btn"
                                onclick="handleTokenAction('@proof.ApplicationUserId', 'increase')">
                            Add token
                        </button>
                        <button class="action-button delete-btn"
                                onclick="handleDelete('@proof.Id')">
                            Delete
                        </button>
                    </div>
                </div>
            }
        </div>
        <div id="imageModal" class="modal">
            <span class="close">&times;</span>
            <img class="modal-content" id="modalImage">
            <a class="download-btn" id="downloadLink" download>Download</a>
        </div>

    </div>
}
@section Scripts{
    <script>

        // Simple upload zone interactions
        const uploadZone = document.getElementById('uploadZone');
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        input.hidden = true;
        input.multiple = true;

        uploadZone.addEventListener('click', () => input.click());
        uploadZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadZone.style.borderColor = '#2563eb';
        });
        uploadZone.addEventListener('dragleave', () => {
            uploadZone.style.borderColor = '#cbd5e1';
        });
        input.addEventListener('change', handleFileUpload);

                      async function handleFileUpload(e) {
            const file = e.target.files[0];
            if (!file) return;

            uploadZone.innerHTML = `<h2>⏳ Uploading...</h2><p>${file.name}</p>`;
            uploadZone.style.borderColor = '#f59e0b';

            const formData = new FormData();
            formData.append('files', file); // ✅ Ensure the key matches .NET API parameter

            try {
                const response = await fetch('/control/home/UploadImage', {
                    method: 'POST',
                    body: formData
                });

                let result;
                const text = await response.text(); // ✅ Read response as text first
                try {
                    result = text ? JSON.parse(text) : {}; // ✅ Parse only if there is content
                } catch (error) {
                    result = { message: "Invalid response from server" };
                }

                if (response.ok) {
                    uploadZone.innerHTML = `<h2>✅ Uploaded!</h2><p>${file.name}</p>`;
                    uploadZone.style.borderColor = '#16a34a';
                } else {
                    throw new Error(result.message || 'Upload failed');
                }
            } catch (error) {
                uploadZone.innerHTML = `<h2>❌ Upload Failed</h2><p>${error.message}</p>`;
                uploadZone.style.borderColor = '#dc2626';
            }
        
        }


        //admin roles
         async function handleTokenAction(userId, action) {
        const btn = event.currentTarget;
        btn.disabled = true;
        btn.innerHTML = `<span class="animate-spin">⏳</span> Processing...`;

        try {
                const response = await fetch(`/control/MenageUsers/IncTokens?id=${userId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            if (response.ok) {
                const userBadge = btn.closest('.flex').previousElementSibling.querySelector('.badge');
                const currentTokens = parseInt(userBadge.textContent.match(/\d+/)[0]);
                userBadge.textContent = `Tokens: ${currentTokens + 1}`;
                showToast('Tokens updated successfully!', 'success');
            } else {
                throw new Error('Failed to update tokens');
            }
        } catch (error) {
            showToast(error.message, 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = `
                Add Token
            `;
        }
    }

    async function handleDelete(proofId) {

        try {
                const response = await fetch(`/control/home/DeleteProof?id=${proofId}`, {
                method: 'POST'
            });

            if (response.ok) {
                card.remove();
                showToast('Proof deleted successfully!', 'success');
            } else {
                throw new Error('Deletion failed');
            }
        } catch (error) {
            showToast(error.message, 'error');
            card.style.opacity = '';
            card.style.pointerEvents = '';
        }
    }

    function showToast(message, type) {
        const toast = document.createElement('div');
        toast.className = `fixed bottom-4 right-4 p-4 rounded-lg text-white ${
            type === 'success' ? 'bg-green-500' : 'bg-red-500'
        }`;
        toast.textContent = message;
        document.body.appendChild(toast);

        setTimeout(() => toast.remove(), 3000);
    }
         
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Modal handling code
            const modal = document.getElementById('imageModal');
            const modalImg = document.getElementById('modalImage');
            const closeBtn = document.querySelector('.close');
            const downloadLink = document.getElementById('downloadLink');

            // Attach click events to proof images
            document.querySelectorAll('.proof-image').forEach(img => {
                img.addEventListener('click', function () {
                    modal.style.display = 'block';
                    modalImg.src = this.src;

                    // Set download filename
                    const ext = this.src.split(';')[0].split('/')[1];
                    downloadLink.download = `payment_proof_${Date.now()}.${ext}`;
                    downloadLink.href = this.src;
                });
            });

            // Close modal interactions
            closeBtn.addEventListener('click', () => modal.style.display = 'none');
            modal.addEventListener('click', (e) => {
                if (e.target === modal) modal.style.display = 'none';
            });

            // Prevent modal close when clicking image/download button
            modalImg.addEventListener('click', (e) => e.stopPropagation());
            downloadLink.addEventListener('click', (e) => e.stopPropagation());

            // ... rest of your existing script code ...
        });
    </script>

        }