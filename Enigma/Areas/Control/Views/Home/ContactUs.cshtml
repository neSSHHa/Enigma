<section style="background-color: #f8f9fa; padding: 60px 0;">
    <div style="width: 80%; margin: 0 auto;">
        <h1 style="text-align: center; font-size: 2.5rem; margin-bottom: 40px;">Contact Us</h1>

        <!-- Contact Information -->
        <div style="display: flex; flex-direction: row; justify-content: space-between; flex-wrap: wrap; margin-bottom: 60px;">
            <!-- Office Address -->
            <div style="flex: 1; min-width: 300px; margin-bottom: 40px;">
                <h2 style="font-size: 1.5rem;">Our Office</h2>
                <p style="font-size: 1rem; line-height: 1.6;">
                    123 Translation Avenue,<br>
                    Language City, LC 12345<br>
                    Serbia
                </p>
                <p style="font-size: 1rem; line-height: 1.6;">
                    Phone: (123) 456-7890<br>
                    Email: <a href="mailto:info@translatoragency.com" style="color: #007bff; text-decoration: underline;">info@translatoragency.com</a>
                </p>
            </div>

            <!-- Business Hours -->
            <div style="flex: 1; min-width: 300px; margin-bottom: 40px;">
                <h2 style="font-size: 1.5rem;">Business Hours</h2>
                <p style="font-size: 1rem; line-height: 1.6;">
                    Monday - Friday: 9:00 AM - 6:00 PM<br>
                    Saturday: 10:00 AM - 2:00 PM<br>
                    Sunday: Closed
                </p>
            </div>

            <!-- Social Media -->
            <div style="flex: 1; min-width: 300px; margin-bottom: 40px;">
                <h2 style="font-size: 1.5rem;">Connect With Us</h2>
                <div style="display: flex; gap: 10px;">
                    <a href="https://facebook.com" target="_blank" style="color: #007bff;">
                        <img src="images/facebook-icon.png" alt="Facebook" style="width: 24px;">
                    </a>
                    <a href="https://twitter.com" target="_blank" style="color: #007bff;">
                        <img src="images/twitter-icon.png" alt="Twitter" style="width: 24px;">
                    </a>
                    <a href="https://linkedin.com" target="_blank" style="color: #007bff;">
                        <img src="images/linkedin-icon.png" alt="LinkedIn" style="width: 24px;">
                    </a>
                    <a href="https://instagram.com" target="_blank" style="color: #007bff;">
                        <img src="images/instagram-icon.png" alt="Instagram" style="width: 24px;">
                    </a>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div style="width: 100%; margin: 0 auto;">
            <h2 style="text-align: center; font-size: 2rem; margin-bottom: 30px;">Get in Touch</h2>
            <form action="submit_form.php" method="post" style="display: flex; flex-direction: column; gap: 20px; max-width: 600px; margin: 0 auto;">
                <div style="display: flex; flex-direction: column;">
                    <label for="name" style="font-size: 1rem; margin-bottom: 10px;">Full Name</label>
                    <input type="text" id="name" name="name" required style="padding: 10px; font-size: 1rem; border: 1px solid #ccc; border-radius: 5px;">
                </div>
                <div style="display: flex; flex-direction: column;">
                    <label for="email" style="font-size: 1rem; margin-bottom: 10px;">Email Address</label>
                    <input type="email" id="email" name="email" required style="padding: 10px; font-size: 1rem; border: 1px solid #ccc; border-radius: 5px;">
                </div>
                <div style="display: flex; flex-direction: column;">
                    <label for="message" style="font-size: 1rem; margin-bottom: 10px;">Your Message</label>
                    <textarea id="message" name="message" rows="5" required style="padding: 10px; font-size: 1rem; border: 1px solid #ccc; border-radius: 5px;"></textarea>
                </div>
                <button type="submit" style="background-color: #007bff; color: #fff; padding: 10px 20px; font-size: 1.2rem; border: none; border-radius: 5px; cursor: pointer;">
                    Send Message
                </button>
            </form>
        </div>
    </div>
</section>
