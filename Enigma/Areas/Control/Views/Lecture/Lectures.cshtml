                                <input type="range" id="maxRange" class="range-slider" name="maxRange" min="1" max="30" value="@Model.MaxLimit" oninput="updateMaxLimit(this.value)" onmouseup="submitThis()">
                    </div>

                    <input asp-for="MaxLimit" id="MaxLimit" hidden />
                </div>
                </div>
