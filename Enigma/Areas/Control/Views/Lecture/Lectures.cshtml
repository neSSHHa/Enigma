                        @StaticDetails.Lecture_Type_Occupaed
                    </button>
                            <button class="toggle-btn"  type="button" id="OpenBtn" onclick="populateInput('@StaticDetails.Lecture_Type_Open', this)">
                        @StaticDetails.Lecture_Type_Open
                    </button>
                </div>
                </div>
                <hr />  
                    <div class="filter-group">

                        <div class="toggle-group">
                    <input asp-for="Status" id="LectureStatus" hidden />
