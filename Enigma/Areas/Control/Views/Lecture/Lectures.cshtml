                            </div>

                            <input asp-for="MaxLimit" id="MaxLimit" hidden />
                        </div>
                    </div>

                    <div class="filter-group">
                        <h3>Date Range</h3>
                        <div class="date-filter">
                            <div class="date-picker-grid">
                                <div class="date-input-group">
                                    <label class="date-label" for="startDate">Start</label>
                                    <div class="date-input-wrapper">
                                        <input type="datetime-local"
                                               id="startDate"
                                               class="date-field"
                                               asp-for="Start"
                                               value="@Model.Start?.ToString("yyyy-MM-ddTHH:mm")"
                                               onchange="updateStartDate(this.value)">
                                        <span class="calendar-icon">⌗</span>
                                    </div>
                                </div>

                                <div class="date-input-group">
                                    <label class="date-label" for="endDate">End</label>
                                    <div class="date-input-wrapper">
                                        <input type="datetime-local"
                                               id="endDate"
                                               class="date-field"
                                               asp-for="End"
                                               value="@Model.End?.ToString("yyyy-MM-ddTHH:mm")"
                                               onchange="updateEndDate(this.value)">
                                        <span class="calendar-icon">⌗</span>
                                    </div>
                                </div>
                            </div>

                            <div class="date-preview">
                                <div class="date-preview-item">
                                    <span class="date-value" id="startDateValue">
                                        @Model.Start?.ToString("dd/MM/yy HH:mm")
                                    </span>
                                    <span class="date-badge">
                                        📅
                                    </span>
                                </div>

                                <div class="date-preview-item">
                                    <span class="date-value" id="endDateValue">
                                        @Model.End?.ToString("dd/MM/yy HH:mm")
                                    </span>
                                    <span class="date-badge">
                                        📅
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

            </form>
        }

    </aside>


        <main class="lecture-grid">
            @foreach (var lecture in Model.Lectures)
            {
                <article class="lecture-card" data-lecture-id="@lecture.Id">
                    <div class="lecture-meta">
                        <span class="lecture-date">@lecture.LectureStartTime.ToString("MMMM dd, yyyy")</span>
                        @{
                            var status = DateTime.Now < lecture.LectureStartTime ? "Upcoming" :
                            DateTime.Now > lecture.LectureEndTIme ? "Completed" : "In Progress";
                        }
                        <span class="lecture-status">● @status</span>
                    </div>
                    <h2 class="lecture-title">@lecture.Name</h2>
                    <div class="lecture-details">
                        <div class="detail-item">
                            <span class="detail-label">Start:</span>
                            <span class="detail-value">@lecture.LectureStartTime.ToString("hh:mm tt")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">End:</span>
                            <span class="detail-value">@lecture.LectureEndTIme.ToString("hh:mm tt")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Students:</span>
                            <span class="detail-value">@(lecture.Students?.Count ?? 0)/@lecture.StudentLimit</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Lecturer:</span>
                            <span class="detail-value">@(lecture.Lecturer?.Name ?? "TBA")</span>
                        </div>
                    </div>
                </article>
            }
        </main>

        <div id="lectureModal" class="modal-overlay">
                <div class="modal-card">
                    <span class="modal-close">&times;</span>
                    <div class="modal-header">
                        <h2 class="modal-title" id="modalLectureName"></h2>
                        <div class="modal-subheader">
                            <span class="modal-date" id="modalLectureDate"></span>
                            <span class="modal-status" id="modalLectureStatus"></span>
                        </div>
                    </div>
                    <div class="modal-body">
                        <div class="modal-grid">
                            <div class="modal-field">
                                <span class="field-label">📝 Description</span>
                                <span class="field-value" id="modalLectureDescription"></span>
                            </div>
                            <div class="modal-field">
                                <span class="field-label">📦 Type</span>
                                <span class="field-value" id="modalLectureType"></span>
                            </div>
                            <div class="modal-field">
                                <span class="field-label">👥 Students</span>
                                <span class="field-value" id="modalLectureStudentLimit"></span>
                            </div>
                            <div class="modal-field">
                                <span class="field-label">⏰ Start Time</span>
                                <span class="field-value" id="modalLectureStartTime"></span>
                            </div>
                            <div class="modal-field">
                                <span class="field-label">⏰ End Time</span>
                                <span class="field-value" id="modalLectureEndTime"></span>
                            </div>
                            <div class="modal-field">
                                <span class="field-label">👨🏫 Lecturer</span>
                                <span class="field-value" id="modalLecturerName"></span>
                            </div>
                        </div>
                    </div>
                @if (User.IsInRole(Utility.StaticDetails.AdminRole))
                {
                    <div class="student-list">
                        <h3 class="student-list-title">Participating Students</h3>
                        <div class="student-list-container" id="studentList">
                            <!-- Student items will be dynamically inserted here -->
                        </div>
                    </div>
                }
                    <div class="modal-footer">
                        <div class="modal-actions">
                            <a id="applyButton" class="btn btn-primary">Apply to Lecture</a>
                            @if (User.IsInRole(StaticDetails.AdminRole))
                            {
                                <a id="EditButton" class="btn btn-secondary">Edit</a>
                                <a id="RemoveButton" class="btn btn-danger">Delete</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
@section Scripts {
    <script>
        function populateInput(value, button) {
            document.getElementById('LectureType').value = value;
            resetButtonStyles('.Type button');
            button.style.backgroundColor = "#e0e0e0";
            submitThis();
        }

        function populateStatus(value, button) {
            document.getElementById('LectureStatus').value = value;
            resetButtonStyles('.status button');
            button.style.backgroundColor = "#e0e0e0";
            submitThis();
        }

        function resetButtonStyles(selector) {
            const buttons = document.querySelectorAll(selector);
            buttons.forEach(btn => btn.style.backgroundColor = "#f1f1f1");
        }

        function updateStartDate(value) {
            document.getElementById("startDateValue").innerText = value;
            submitThis();
        }

        function updateEndDate(value) {
            document.getElementById("endDateValue").innerText = value;
            submitThis();
        }

        function updateMaxLimit(value) {
            document.getElementById("maxValue").innerText = value;
            document.getElementById("MaxLimit").value = value;

        }
        function submitThis(){
            document.getElementById("generalSubmit").click();
        }

        function setUpButtons() {
            var typeValue = document.getElementById('LectureType').value
            switch(typeValue)
            {
                case "OCCUPAED":
                    resetButtonStyles('.Type button');
                    document.getElementById("OccupiedBtn").style.backgroundColor = "#0a0a0a";
                    document.getElementById("OccupiedBtn").style.color = "#fafafa";

                    break;
                case "OPEN":
                    resetButtonStyles('.Type button');
                    document.getElementById("OpenBtn").style.backgroundColor = "#0a0a0a";
                    document.getElementById("OpenBtn").style.color = "#fafafa";

                break;
            }
            var statusValue = document.getElementById('LectureStatus').value
            switch (statusValue) {
                case "FINISHED":
                    resetButtonStyles('.status button');
                    document.getElementById("FinishedBtn").style.backgroundColor = "#0a0a0a";
                    document.getElementById("FinishedBtn").style.color = "#fafafa";

                    break;
                case "AWAITS":
                    resetButtonStyles('.status button');
                    document.getElementById("AwaitsBtn").style.backgroundColor = "#0a0a0a";
                    document.getElementById("AwaitsBtn").style.color = "#fafafa";

                    break;
                case "CANCELED":
                    resetButtonStyles('.status button');
                    document.getElementById("CanceledBtn").style.backgroundColor = "#0a0a0a";
                    document.getElementById("CanceledBtn").style.color = "#fafafa";

                    break;
            }

        }
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('lectureModal');
        const closeBtn = document.querySelector('.modal-close'); // Was '.close'

            // Show modal
            document.querySelectorAll('.lecture-card').forEach(card => {
                card.addEventListener('click', async function() {
                    const lectureId = this.dataset.lectureId;
                    const lecture = await getLectureById(lectureId);
                    if (lecture) {
                        populateModal(lecture);
                        modal.style.display = 'flex';
                    }
                });
            });

            // Close modal
            function closeModal() {
                document.getElementById('lectureModal').style.display = 'none';
                }

            // Event listeners
            closeBtn.addEventListener('click', closeModal);
            window.addEventListener('click', (e) => {
                if (e.target === modal) closeModal();
            });

            async function getLectureById(id) {
                try {
                    const response = await fetch(`/Control/lecture/GetLecture/${id}`);
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return await response.json();
                } catch (error) {
                    console.error('Error fetching lecture:', error);
                }
            }

            function populateModal(lecture) {
                var button1 = document.getElementById('EditButton');
                if (button1 != null) {
                    button1.setAttribute('href', "/Control/Lecture/EditLecture/" + lecture.id);
                }
                var button2 = document.getElementById('EditButton');
                if (button2 != null) {
                    button2.setAttribute('href', "/Control/Lecture/RemoveLecture/" + lecture.id);
                }

                document.getElementById('applyButton').setAttribute('href', "/Control/Lecture/Apply/" + lecture.id);

                document.getElementById('modalLectureName').textContent = lecture.name;
                document.getElementById('modalLectureDate').textContent = new Date(lecture.lectureStartTime).toLocaleDateString();
                document.getElementById('modalLectureDescription').textContent = lecture.description;
                document.getElementById('modalLectureType').textContent = lecture.type;
                document.getElementById('modalLectureStudentLimit').textContent = (lecture.students ? lecture.students.length : "0") + "/" +  lecture.studentLimit;
                document.getElementById('modalLectureStatus').textContent = lecture.lectureStatus;
                document.getElementById('modalLectureStartTime').textContent = new Date(lecture.lectureStartTime).toLocaleTimeString();
                document.getElementById('modalLectureEndTime').textContent = new Date(lecture.lectureEndTIme).toLocaleTimeString();
                document.getElementById('modalLecturerName').textContent = lecture.lecturer ? lecture.lecturer.name : 'Not available';

                     // Populate students only for admins
        @if (User.IsInRole(Utility.StaticDetails.AdminRole))
        {
            <text>
                const studentList = document.getElementById('studentList');
                studentList.innerHTML = ''; // Clear existing content

                if (lecture.students && lecture.students.length > 0) {
                    lecture.students.forEach(student => {
                        const studentEl = document.createElement('div');
                        studentEl.className = 'student-item';

                        // Create avatar with initial
                        const avatar = document.createElement('div');
                        avatar.className = 'student-avatar';
                        avatar.textContent = student.name ? student.name.charAt(0).toUpperCase() : '?';

                        // Student info
                        const info = document.createElement('div');
                        info.className = 'student-info';

                        const name = document.createElement('div');
                        name.className = 'student-name';
                        name.textContent = student.name || 'Unknown Student';

                        const email = document.createElement('div');
                        email.className = 'student-email';
                        email.textContent = student.email;

                        info.appendChild(name);
                        info.appendChild(email);

                        studentEl.appendChild(avatar);
                        studentEl.appendChild(info);
                        studentList.appendChild(studentEl);
                    });
                } else {
                    const empty = document.createElement('div');
                    empty.className = 'no-students';
                    empty.textContent = 'No students have joined yet';
                    studentList.appendChild(empty);
                }
            </text>
        }
            }
        });
        window.onload = setUpButtons;
    </script>
}