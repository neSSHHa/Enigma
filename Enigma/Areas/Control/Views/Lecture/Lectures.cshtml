            </form>
        }
        else
        {
            <form method="post" asp-action="LecturesPOST">
                <a asp-action="YourLectures" class="btn btn-secondary">View lectures to attend</a>
                <input asp-for="Type" id="LectureType" hidden />
                <input asp-for="Status" id="LectureStatus" hidden />

