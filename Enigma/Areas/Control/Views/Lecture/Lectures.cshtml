                        @StaticDetails.Lecture_Status_Awaits
                    </button>
                            <button class="toggle-btn"  type="button" id="CanceledBtn" onclick="populateStatus('@StaticDetails.Lecture_status_Canceled', this)">
                        @StaticDetails.Lecture_status_Canceled
                    </button>
                </div>
                </div>

                    <div class="filter-group">

