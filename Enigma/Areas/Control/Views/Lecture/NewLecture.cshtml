@using Models.Models
@model Lecture
@{
    ViewData["Title"] = "New Lecture";
}

<h1>New Lecture</h1>

<!-- Updated CSS for White Theme -->
<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f9f9f9; /* Light background */
        color: #333; /* Darker text */
        margin: 0;
       
    }

    h1 {
        font-size: 2.5rem;
        text-align: center;
        margin-bottom: 20px;
        color: #333; /* Dark text */
    }

    #formPst {
        background-color: #fff; /* White form background */
        padding: 30px;
        border-radius: 10px;
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1); /* Soft shadow */
        display: flex;
        flex-direction: column;
        gap: 20px;
        border: 1px solid #e0e0e0; /* Light border */
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    label {
        font-size: 1.1rem;
        color: #555; /* Medium gray for labels */
    }

    input, textarea {
        background-color: #fff; /* White input background */
        color: #333; /* Dark text */
        padding: 15px;
        border: 1px solid #ccc; /* Light gray border */
        border-radius: 5px;
        font-size: 1rem;
        transition: border 0.3s ease, box-shadow 0.3s ease;
        width: 100%;
    }

    textarea {
        resize: vertical;
        min-height: 100px;
    }

    input:focus, textarea:focus {
        border: 2px solid #007bff; /* Blue focus border */
        box-shadow: 0 0 5px rgba(0, 123, 255, 0.3); /* Soft blue shadow */
        outline: none;
    }

    #submitbtn {
        background-color: #007bff; /* Blue button */
        color: #fff;
        padding: 15px;
        font-size: 1.2rem;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.2s ease;
    }

    #submitbtn:hover {
        background-color: #0056b3; /* Darker blue on hover */
        transform: translateY(-3px); /* Slight lift effect */
    }

    #submitbtn:active {
        transform: translateY(0); /* Reset lift effect on click */
    }

    /* Responsive design for smaller screens */
    @@media (max-width: 768px) {
        form {
            padding: 20px;
            max-width: 100%;
        }
        
        h1 {
            font-size: 2rem;
        }
    }
</style>

<!-- Form HTML -->
<form id="formPst" method="post" asp-action="NewLecturePost">
    <div class="form-group">
        <label asp-for="Name">Lecture Name</label>
        <input asp-for="Name" placeholder="Enter lecture name" />
    </div>

    <div class="form-group">
        <label asp-for="Description">Description</label>
        <textarea asp-for="Description" placeholder="Describe the lecture"></textarea>
    </div>

    <div class="form-group">
        <label asp-for="LectureStartTime">Start Time</label>
        <input asp-for="LectureStartTime" type="datetime-local" />
    </div>

    <div class="form-group">
        <label asp-for="LectureEndTIme">End Time</label>
        <input asp-for="LectureEndTIme" type="datetime-local" />
    </div>

    <div class="form-group">
        <label asp-for="StudentLimit">Student Limit</label>
        <input asp-for="StudentLimit" type="number" min="1" placeholder="Set student limit" />
    </div>

    <button id="submitbtn" type="submit">Submit</button>
</form>

@section Scripts{
    <script>
        document.querySelector('form').addEventListener('submit', function (e) {
            e.preventDefault(); // Prevent the form from submitting for demonstration purposes

            const inputs = document.querySelectorAll('input');
            inputs.forEach(input => {
                if (!input.value) {
                    input.style.border = '2px solid red'; // Highlight empty fields with red border
                } else {
                    input.style.border = '';
                }
            });

            // Additional form validation logic can be added here
        });
    </script>
}
